# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/petluri_lms

# Auth
JWT_SECRET=your_jwt_secret_here

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password_or_app_password
FROM_NAME=Petluri Edutech
FROM_EMAIL=your_email@gmail.com

# Alternate Email Config (used in some controllers)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_or_app_password

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend
CLIENT_URL=http://localhost:5173

# Backblaze B2 (S3 compatible video storage)
B2_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_BUCKET_NAME=your_bucket_name
B2_KEY_ID=your_key_id
B2_APP_KEY=your_application_key
B2_VIDEO_PREFIX=videos
B2_PUBLIC_BASE_URL=https://s3.us-east-005.backblazeb2.com/your_bucket_name
